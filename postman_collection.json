{
  "info": {
    "name": "VSMS API",
    "description": "Vehicle Service Management System REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"USER\",\n  \"phone\": \"+1-555-0100\",\n  \"address\": \"221B Baker St\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "Create Vehicle",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/vehicles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Toyota Corolla\",\n  \"year\": 2020,\n  \"licensePlate\": \"ABC-1234\",\n  \"vin\": \"1HGCM82633A123456\"\n}"
            }
          }
        },
        {
          "name": "List Vehicles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/v1/vehicles"
          }
        },
        {
          "name": "Update Vehicle",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/vehicles/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Toyota Corolla LE\",\n  \"year\": 2021\n}"
            }
          }
        },
        {
          "name": "Delete Vehicle",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/v1/vehicles/:id"
          }
        }
      ]
    },
    {
      "name": "Service Requests",
      "item": [
        {
          "name": "Create Service Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/services",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleId\": \"<vehicle-uuid>\",\n  \"issueDescription\": \"Engine making knocking noise\",\n  \"serviceType\": \"REGULAR\",\n  \"scheduledDate\": \"2026-06-01T10:00:00.000Z\"\n}"
            }
          }
        },
        {
          "name": "List Service Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/v1/services"
          }
        },
        {
          "name": "Update Service Request",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/services/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            }
          }
        },
        {
          "name": "Delete Service Request",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/v1/services/:id"
          }
        }
      ]
    }
  ]
}
